# 请使用新生成的密钥，不要把真实密钥提交到 Git
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 填写你的 DashScope 账号当前可用、且支持图片输入的模型名称
QWEN_VL_MODEL=qwen3-vl-plus

# 首次运行可留空。日志会显示发送者 ID，之后填入以限制使用者。
ALLOWED_USER_IDS=

MAX_ARTICLE_IMAGES=8
REQUEST_TIMEOUT_SECONDS=20

# 可选：整理成功后自动写入飞书电子表格
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SPREADSHEET_TOKEN=
FEISHU_SHEET_ID=
FEISHU_WIKI_NODE_TOKEN=
FEISHU_SPREADSHEET_URL=
